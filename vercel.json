{
    "redirects": [
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "www.smartwebkit.net"
                }
            ],
            "destination": "https://smartwebkit.net/:path*",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/((?!assets/|sitemap\\.xml|robots\\.txt|ads\\.txt|favicon\\..*|.*\\..*).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/sitemap.xml",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/xml; charset=utf-8"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=86400, s-maxage=86400"
                }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/plain; charset=utf-8"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=86400, s-maxage=86400"
                }
            ]
        }
    ]
}
